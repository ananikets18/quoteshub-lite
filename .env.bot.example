# Example .env configuration for Bot System

# Add these to your existing .env file

#----------------------------------------------------------
# BOT SYSTEM CONFIGURATION
#----------------------------------------------------------

# Enable or disable the bot system
# Set to true to enable bot activities
BOT_SYSTEM_ENABLED=false

# Number of bot users to create
BOT_USER_COUNT=50

# Activity frequencies (actions per hour)
# Adjust based on your desired activity level
BOT_QUOTES_PER_HOUR=10
BOT_LIKES_PER_HOUR=50
BOT_SAVES_PER_HOUR=20
BOT_FOLLOWS_PER_HOUR=15
BOT_VIEWS_PER_HOUR=100

# Optional: Bot name prefix (leave empty for natural names)
BOT_NAME_PREFIX=

# Logging settings
BOT_LOGGING_ENABLED=true
BOT_LOG_CHANNEL=stack

#----------------------------------------------------------
# RECOMMENDED SETTINGS FOR DIFFERENT STAGES
#----------------------------------------------------------

# DEVELOPMENT / TESTING
# BOT_SYSTEM_ENABLED=true
# BOT_USER_COUNT=20
# BOT_QUOTES_PER_HOUR=5
# BOT_LIKES_PER_HOUR=20
# BOT_SAVES_PER_HOUR=10
# BOT_FOLLOWS_PER_HOUR=5
# BOT_VIEWS_PER_HOUR=50

# PRODUCTION - INITIAL LAUNCH (Days 1-30)
# BOT_SYSTEM_ENABLED=true
# BOT_USER_COUNT=50
# BOT_QUOTES_PER_HOUR=15
# BOT_LIKES_PER_HOUR=60
# BOT_SAVES_PER_HOUR=25
# BOT_FOLLOWS_PER_HOUR=20
# BOT_VIEWS_PER_HOUR=150

# PRODUCTION - GROWTH PHASE (Days 31-90)
# BOT_SYSTEM_ENABLED=true
# BOT_USER_COUNT=50
# BOT_QUOTES_PER_HOUR=10
# BOT_LIKES_PER_HOUR=40
# BOT_SAVES_PER_HOUR=15
# BOT_FOLLOWS_PER_HOUR=10
# BOT_VIEWS_PER_HOUR=100

# PRODUCTION - ESTABLISHED (90+ days with real users)
# BOT_SYSTEM_ENABLED=false
# (Keep disabled once you have sufficient real user activity)
